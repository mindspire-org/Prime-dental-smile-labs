# ── Server ──────────────────────────────────────────────
PORT=8080
APP_URL=https://your-domain.com
API_PORT=3001

# ── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/prime-smile-lab

# ── Auth (use strong random secrets in production) ───────
JWT_ACCESS_SECRET=change-this-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars

# ── CORS (comma-separated allowed origins) ───────────────
CORS_ORIGIN=http://localhost:8080,http://localhost:3000,http://localhost:5173

# ── Email / SMTP ─────────────────────────────────────────
# Leave SMTP_HOST empty to skip sending emails (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Prime Smile Labs <no-reply@primesmile.co.uk>
CONTACT_EMAIL=support@primesmilelab.com

# ── Google Analytics 4 (Vite prefix required for browser access) ─────────────
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google reCAPTCHA ─────────────────────────────────────
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ── File Storage (S3 / Cloudflare R2) ────────────────────
# Leave S3_BUCKET empty to disable file upload features
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=prime-smile-cases
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# ── Security Settings ────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=change-this-session-secret-min-32-chars

# ── Application Settings ─────────────────────────────────
APP_NAME=Prime Smile Dental Laboratory
NODE_ENV=development
DEBUG=true

# ── Dental Lab Specific ─────────────────────────────────
LAB_PHONE_UK=+44 20 1234 5678
LAB_PHONE_CYPRUS=+357 99 123456
LAB_WHATSAPP=+357 99 123456
