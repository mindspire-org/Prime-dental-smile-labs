# Prime Smile Labs — production environment.
# Copy to the PROJECT ROOT as `.env` (NOT into backend/):
#   cp deploy/.env.example /var/www/Prime-dental-smile-labs/.env
# server.mjs loads this via `dotenv/config` at startup.

# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=production
# Port the Node process listens on (nginx proxies to this).
PORT=8080
# Public URL of the site (used in emails / links).
APP_URL=https://primesmile.example.com
# Comma-separated allowed origins for CORS. Use your real domain in prod.
CORS_ORIGIN=https://primesmile.example.com

# ── Database (required) ──────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/primesmile

# ── Auth secrets (required — generate with: openssl rand -hex 48) ─────
JWT_ACCESS_SECRET=CHANGE_ME_long_random_string
JWT_REFRESH_SECRET=CHANGE_ME_different_long_random_string

# ── Email / SMTP (contact form + notifications) ──────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Prime Smile Labs <no-reply@primesmile.example.com>"
CONTACT_EMAIL=info@primesmile.example.com

# ── reCAPTCHA (contact form anti-spam; leave blank to disable) ───────
RECAPTCHA_SECRET_KEY=

# ── S3-compatible object storage (optional) ──────────────────────────
# If unset, uploads are stored on local disk under backend/uploads.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# ── Seed script only (npm run seed) ──────────────────────────────────
SEED_ADMIN_EMAIL=admin@primesmile.example.com
SEED_DENTIST_EMAIL=dentist@primesmile.example.com
SEED_PASSWORD=CHANGE_ME

# NOTE: API_PORT is only used by the backend dev-server (npm run dev).
# In production the single server.mjs process uses PORT above.
