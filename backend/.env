# ── MongoDB ──────────────────────────────────────────────
# Option A: Local MongoDB (default — install MongoDB Community from https://www.mongodb.com/try/download/community)
MONGODB_URI=mongodb://127.0.0.1:27017/prime-smile-lab

# Option B: MongoDB Atlas (cloud) — replace the line above with your Atlas connection string:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/prime-smile-lab?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=primesmile_access_secret_change_in_production
JWT_REFRESH_SECRET=primesmile_refresh_secret_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
APP_URL=http://localhost:8080

# ── Server ────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ── Email (optional — leave blank to skip email sending) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@primesmilelab.com

# ── File Storage (optional S3) ───────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
AWS_S3_BUCKET=
